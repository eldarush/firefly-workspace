{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Firefly Workspace configuration (.firefly/config.json)",
  "type": "object",
  "properties": {
    "version": { "type": "integer", "default": 1 },
    "personas": {
      "type": "array",
      "items": { "enum": ["sre", "qa", "dev", "research"] },
      "description": "Active personas; weight playbook lesson selection."
    },
    "behavior": {
      "type": "object",
      "properties": {
        "stop_gate": { "type": "boolean", "default": true, "description": "Block premature completion after unverified code edits." },
        "prompt_frame": { "type": "boolean", "default": true, "description": "Inject a short task-framing nudge on new nontrivial tasks." },
        "lessons_injection": { "type": "boolean", "default": true, "description": "Inject top playbook lessons at SessionStart." },
        "auto_allow_read": { "type": "boolean", "default": false, "description": "Auto-approve read-only commands (loosens permissions; opt-in)." },
        "destroy": { "enum": ["deny", "ask"], "default": "deny" },
        "mutate_in_protected": { "enum": ["deny", "ask"], "default": "deny" },
        "max_stop_blocks_per_session": { "type": "integer", "default": 2 }
      }
    },
    "protected": {
      "type": "object",
      "description": "Glob patterns marking production-like targets.",
      "properties": {
        "contexts": { "type": "array", "items": { "type": "string" } },
        "namespaces": { "type": "array", "items": { "type": "string" } }
      }
    },
    "verify": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Project verifier commands (first one is suggested by the stop gate)."
        },
        "code_suffixes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "lessons": {
      "type": "object",
      "properties": {
        "max_inject": { "type": "integer", "default": 6 },
        "max_inject_tokens": { "type": "integer", "default": 1200 },
        "max_active": { "type": "integer", "default": 100 },
        "max_per_scope": { "type": "integer", "default": 20 },
        "decay_half_life_weeks": { "type": "number", "default": 4 },
        "trial_slots": { "type": "integer", "default": 1 }
      }
    },
    "learning": {
      "type": "object",
      "description": "The automatic learning loop (no commands needed).",
      "properties": {
        "auto_reflect": { "type": "boolean", "default": true, "description": "Once per session at Stop, ask the model to distill fresh signals into playbook delta-ops." },
        "auto_reflect_min_candidates": { "type": "integer", "default": 2, "description": "Fresh signals required before auto-retro triggers." },
        "auto_reflect_min_turns": { "type": "integer", "default": 3, "description": "Skip auto-retro for trivial sessions shorter than this." },
        "auto_lessons": { "type": "boolean", "default": true, "description": "Deterministically propose lessons for signals recurring across sessions." },
        "auto_feedback": { "type": "boolean", "default": true, "description": "Verified, correction-free sessions give +1 helpful to injected lessons." },
        "min_recurrence": { "type": "integer", "default": 2, "description": "Distinct sessions a signal must recur in before an auto-lesson is proposed." }
      }
    },
    "docs": {
      "type": "object",
      "properties": {
        "kiwix_url": { "type": "string", "description": "Internal Kiwix/WikiAll base URL, e.g. http://wikiall.internal:8090" },
        "extra_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "deny_extra": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Extra regexes treated as destructive (denied)."
    },
    "allow_extra": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Extra regexes treated as read-only."
    }
  }
}
